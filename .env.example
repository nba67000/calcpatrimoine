# Umami Analytics Configuration
# Ces valeurs vont dans src/app/layout.tsx

# Domaine de ton instance Umami déployée sur Vercel
# Exemple: umami-analytics-abc123.vercel.app
NEXT_PUBLIC_UMAMI_DOMAIN=TON-UMAMI-DOMAINE.vercel.app

# Website ID de CalcPatrimoine dans Umami
# Exemple: a1b2c3d4-e5f6-7890-abcd-ef1234567890
NEXT_PUBLIC_UMAMI_WEBSITE_ID=TON-WEBSITE-ID

# Note: Ces variables ne sont pas utilisées par Next.js directement,
# elles sont hard-codées dans layout.tsx pour être intégrées au build
# (évite les variables d'environnement runtime pour les analytics)
